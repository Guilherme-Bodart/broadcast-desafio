rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(data) {
      return isSignedIn() && data.userId == request.auth.uid;
    }

    function hasValidTimestamps(data) {
      return data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    function keepsBaseFields(resourceData, requestData) {
      return resourceData.userId == requestData.userId
        && resourceData.createdAt == requestData.createdAt;
    }

    function keepsConnectionScope(resourceData, requestData) {
      return keepsBaseFields(resourceData, requestData)
        && resourceData.connectionId == requestData.connectionId;
    }

    function ownsConnection(connectionId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/connections/$(connectionId))
        && get(/databases/$(database)/documents/connections/$(connectionId)).data.userId == request.auth.uid;
    }

    function hasValidConnectionData(data) {
      return data.keys().hasAll(['userId', 'name', 'createdAt', 'updatedAt'])
        && data.keys().hasOnly(['userId', 'name', 'createdAt', 'updatedAt'])
        && data.name is string
        && data.name.size() > 0
        && data.name.size() <= 80
        && hasValidTimestamps(data);
    }

    function hasValidContactData(data) {
      return data.keys().hasAll(['userId', 'connectionId', 'name', 'phone', 'createdAt', 'updatedAt'])
        && data.keys().hasOnly(['userId', 'connectionId', 'name', 'phone', 'createdAt', 'updatedAt'])
        && data.connectionId is string
        && data.name is string
        && data.name.size() > 0
        && data.name.size() <= 120
        && data.phone is string
        && data.phone.size() >= 8
        && data.phone.size() <= 20
        && hasValidTimestamps(data);
    }

    function hasValidMessageData(data) {
      return data.keys().hasAll(['userId', 'connectionId', 'contactIds', 'text', 'status', 'scheduledAt', 'sentAt', 'createdAt', 'updatedAt'])
        && data.keys().hasOnly(['userId', 'connectionId', 'contactIds', 'text', 'status', 'scheduledAt', 'sentAt', 'createdAt', 'updatedAt'])
        && data.connectionId is string
        && data.contactIds is list
        && data.contactIds.size() > 0
        && data.contactIds.size() <= 500
        && data.text is string
        && data.text.size() > 0
        && data.text.size() <= 1000
        && data.status in ['scheduled', 'sent']
        && (data.scheduledAt == null || data.scheduledAt is timestamp)
        && (data.sentAt == null || data.sentAt is timestamp)
        && hasValidTimestamps(data)
        && ((data.status == 'scheduled' && data.scheduledAt is timestamp && data.sentAt == null)
          || (data.status == 'sent' && data.scheduledAt == null && data.sentAt is timestamp));
    }

    match /connections/{connectionId} {
      allow read: if isOwner(resource.data);
      allow create: if isOwner(request.resource.data)
        && hasValidConnectionData(request.resource.data);
      allow update: if isOwner(resource.data)
        && isOwner(request.resource.data)
        && keepsBaseFields(resource.data, request.resource.data)
        && hasValidConnectionData(request.resource.data);
      allow delete: if isOwner(resource.data);
    }

    match /contacts/{contactId} {
      allow read: if isOwner(resource.data);
      allow create: if isOwner(request.resource.data)
        && ownsConnection(request.resource.data.connectionId)
        && hasValidContactData(request.resource.data);
      allow update: if isOwner(resource.data)
        && isOwner(request.resource.data)
        && keepsConnectionScope(resource.data, request.resource.data)
        && ownsConnection(request.resource.data.connectionId)
        && hasValidContactData(request.resource.data);
      allow delete: if isOwner(resource.data)
        && ownsConnection(resource.data.connectionId);
    }

    match /messages/{messageId} {
      allow read: if isOwner(resource.data);
      allow create: if isOwner(request.resource.data)
        && ownsConnection(request.resource.data.connectionId)
        && hasValidMessageData(request.resource.data);
      allow update: if isOwner(resource.data)
        && isOwner(request.resource.data)
        && keepsConnectionScope(resource.data, request.resource.data)
        && ownsConnection(request.resource.data.connectionId)
        && hasValidMessageData(request.resource.data);
      allow delete: if isOwner(resource.data)
        && ownsConnection(resource.data.connectionId);
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
